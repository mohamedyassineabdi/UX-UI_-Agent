# Copy this file to /etc/ux-ui-auditor.env on the server.
# Do not commit real secrets.

PYTHONUNBUFFERED=1

# Optional: AI review backend. Supported values in code: ollama, groq, openai.
AI_REVIEW_BACKEND=ollama
AI_REVIEW_BASE_URL=http://127.0.0.1:11434
AI_REVIEW_MODEL=llama3.2
AI_REVIEW_API_KEY=
AI_REVIEW_TIMEOUT=120

# Optional: Ollama / crawler / GTM vision settings.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_VISION_MODEL=llama3.2-vision
OLLAMA_API_KEY=
GTM_VISION_BASE_URL=http://127.0.0.1:11434
GTM_VISION_MODEL=llama3.2-vision
GTM_VISION_API_KEY=

# Keep AI navigation off unless the configured model is available and tested.
CRAWLER_USE_AI_NAV=0
USE_AI_NAV=0

# Vercel CLI. Prefer logging in and linking on the server.
VERCEL_TOKEN=

# Mobile audits require Appium/ADB to be installed separately.
ANDROID_HOME=
ANDROID_SDK_ROOT=
